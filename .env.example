# Copy this file to .env and replace placeholder values with your actual keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

NEXT_PUBLIC_APP_URL=http://localhost:4028

# SMS — BulkSMS.com (group/church SMS broadcasts — cell number from membership form)
SMS_PROVIDER=bulksms
BULKSMS_BASIC_AUTH=

# Super admin (platform owner — email sign-in only)
SUPER_ADMIN_EMAIL=your-email@gmail.com
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=your-email@gmail.com

# Email sign-in + invites — https://resend.com (one-click links, no codes to type)
# Mailchimp is NOT used for sign-in — only for newsletters/broadcasts (see below).
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="CKC Church <noreply@ckcmidrand.org>"

# Mailchimp — newsletters / email broadcast only
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_FROM_NAME=Christ Kingdom Citizens Midrand
MAILCHIMP_FROM_EMAIL=ckcmidrand@gmail.com
MAILCHIMP_REPLY_TO=ckcmidrand@gmail.com
