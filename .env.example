# Copy this file to .env and replace placeholder values with your actual keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

NEXT_PUBLIC_APP_URL=http://localhost:4028

# SMS — BulkSMS.com
SMS_PROVIDER=bulksms
BULKSMS_BASIC_AUTH=

# Super admin (platform owner — email sign-in only)
SUPER_ADMIN_EMAIL=your-email@gmail.com
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=your-email@gmail.com

# Email OTP — https://resend.com
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=CKC Church <onboarding@resend.dev>

# Trusted device tokens (Expo will use same API)
DEVICE_TRUST_DAYS=90
DEVICE_TRUST_SECRET=change-this-to-a-long-random-string

# Mailchimp — newsletters / email broadcast
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_FROM_NAME=Christ Kingdom Citizens
MAILCHIMP_REPLY_TO=your-email@gmail.com
